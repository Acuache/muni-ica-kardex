# Supabase — copia este archivo a `.env` y rellena los valores del proyecto.
# `.env` está en .gitignore (nunca se commitea); solo `.env.example` se versiona.

# URL del proyecto Supabase (pública).
NEXT_PUBLIC_SUPABASE_URL=

# Llave publicable (anon) — segura para el navegador; la RLS la controla.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Llave secreta (service role) — Spec 04. Se salta la RLS y ejerce la Auth
# Admin API (crear/eliminar/resetear cuentas). SIN prefijo NEXT_PUBLIC_ para
# que Next nunca la incluya en el bundle del cliente; se usa solo en el cliente
# server-only `lib/supabase/admin.ts`, dentro de Server Actions. NO la compartas.
SUPABASE_SERVICE_ROLE_KEY=
